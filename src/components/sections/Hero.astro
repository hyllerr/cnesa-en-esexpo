---
---

<section class="relative bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 text-white py-20 lg:py-32 overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, white 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <div class="container-wide relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="inline-block bg-primary-500/20 border border-primary-400/30 rounded-full px-4 py-1 text-sm font-medium mb-6">
          April 15-17, 2026 • Beijing, China
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          ESIE 2026
          <span class="block text-primary-300 mt-2">International Energy Storage & Hydrogen Expo</span>
        </h1>
        <p class="text-xl text-gray-200 mb-8 max-w-xl">
          The largest energy storage exhibition in China. 1000+ exhibitors, 100,000+ visitors, 
          200+ industry leaders. Join us for the 12th edition.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/visit/" class="btn-primary bg-white text-primary-700 hover:bg-gray-100">
            Register as Visitor
          </a>
          <a href="/contact/" class="btn-secondary border-white text-white hover:bg-white hover:text-primary-700">
            Become an Exhibitor
          </a>
        </div>
      </div>

      <div class="hidden lg:block">
        <div class="grid grid-cols-2 gap-6">
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 text-center">
            <div class="text-4xl font-bold text-white">1,200+</div>
            <div class="text-gray-300 mt-1">Exhibitors</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 text-center">
            <div class="text-4xl font-bold text-white">100,000+</div>
            <div class="text-gray-300 mt-1">Visitors</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 text-center">
            <div class="text-4xl font-bold text-white">200+</div>
            <div class="text-gray-300 mt-1">Speakers</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 text-center">
            <div class="text-4xl font-bold text-white">12</div>
            <div class="text-gray-300 mt-1">Years Running</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
