---
---

<section class="py-16 lg:py-24">
  <div class="container-wide">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Keynote Speakers</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Learn from industry experts, researchers, and policymakers at the forefront of energy innovation.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {Array.from({ length: 4 }).map((_, i) => (
        <div class="text-center group">
          <div class="w-32 h-32 mx-auto bg-gray-200 rounded-full mb-4 overflow-hidden group-hover:scale-105 transition-transform">
            <div class="w-full h-full bg-gradient-to-br from-primary-200 to-primary-400 flex items-center justify-center">
              <svg class="w-16 h-16 text-white/50" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
              </svg>
            </div>
          </div>
          <h3 class="font-semibold text-lg">Speaker Name</h3>
          <p class="text-gray-600">Job Title • Company</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <a href="/speakers/" class="btn-secondary">
        View All Speakers →
      </a>
    </div>
  </div>
</section>
