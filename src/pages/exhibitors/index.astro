---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<BaseLayout title="Exhibitors" description="Browse all exhibitors at ESIE 2026. Find companies showcasing the latest energy storage and hydrogen technologies.">
  <Header />
  <main>
    <section class="bg-gray-50 py-12">
      <div class="container-wide">
        <h1 class="text-4xl font-bold mb-4">Exhibitors</h1>
        <p class="text-gray-600 max-w-2xl">
          Browse our comprehensive list of exhibitors showcasing the latest innovations in energy storage, batteries, hydrogen, and renewable energy technologies.
        </p>
      </div>
    </section>

    <section class="py-12">
      <div class="container-wide">
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 text-center">
          <p class="text-yellow-800">
            🚧 Content coming soon! Check back for the full list of ESIE 2026 exhibitors.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
