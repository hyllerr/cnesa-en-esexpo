---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<BaseLayout title="Agenda" description="View the full conference agenda for ESIE 2026. Three days of keynotes, panels, and technical sessions.">
  <Header />
  <main>
    <section class="bg-gray-50 py-12">
      <div class="container-wide">
        <h1 class="text-4xl font-bold mb-4">Conference Agenda</h1>
        <p class="text-gray-600 max-w-2xl">
          Three days of keynotes, panel discussions, and technical sessions covering the entire energy storage and hydrogen value chain.
        </p>
      </div>
    </section>

    <section class="py-12">
      <div class="container-wide">
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 text-center">
          <p class="text-yellow-800">
            🚧 Content coming soon! Check back for the full ESIE 2026 agenda.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
