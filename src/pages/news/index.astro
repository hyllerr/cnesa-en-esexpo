---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<BaseLayout title="News" description="Stay updated with the latest news and announcements from ESIE 2026.">
  <Header />
  <main>
    <section class="bg-gray-50 py-12">
      <div class="container-wide">
        <h1 class="text-4xl font-bold mb-4">News & Press</h1>
        <p class="text-gray-600 max-w-2xl">
          Stay updated with the latest announcements, press releases, and industry news from ESIE.
        </p>
      </div>
    </section>

    <section class="py-12">
      <div class="container-wide">
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 text-center">
          <p class="text-yellow-800">
            🚧 Content coming soon! Check back for the latest ESIE news.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
