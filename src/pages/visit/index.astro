---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<BaseLayout title="Visit" description="Plan your visit to ESIE 2026 in Beijing. Registration, venue information, travel tips, and more.">
  <Header />
  <main>
    <section class="bg-gray-50 py-12">
      <div class="container-wide">
        <h1 class="text-4xl font-bold mb-4">Plan Your Visit</h1>
        <p class="text-gray-600 max-w-2xl">
          Everything you need to know about attending ESIE 2026: registration, venue, travel, and accommodation.
        </p>
      </div>
    </section>

    <section class="py-12">
      <div class="container-wide">
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 text-center">
          <p class="text-yellow-800">
            🚧 Content coming soon! Check back for visitor information.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
