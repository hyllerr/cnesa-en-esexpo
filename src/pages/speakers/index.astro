---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<BaseLayout title="Speakers" description="Meet the speakers at ESIE 2026. Industry leaders, researchers, and policymakers sharing insights on energy storage and hydrogen.">
  <Header />
  <main>
    <section class="bg-gray-50 py-12">
      <div class="container-wide">
        <h1 class="text-4xl font-bold mb-4">Speakers</h1>
        <p class="text-gray-600 max-w-2xl">
          Learn from industry leaders, researchers, and policymakers at the forefront of energy storage and hydrogen technology innovation.
        </p>
      </div>
    </section>

    <section class="py-12">
      <div class="container-wide">
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6 text-center">
          <p class="text-yellow-800">
            🚧 Content coming soon! Check back for the full list of ESIE 2026 speakers.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
